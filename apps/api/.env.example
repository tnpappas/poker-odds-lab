# Copy to .env and fill in. Without DATABASE_URL the API runs with an
# in-memory store (data resets on restart) — handy for local development.

# Database (Neon Postgres)
DATABASE_URL=

# Auth (Clerk). Without CLERK_SECRET_KEY the API runs in dev-auth mode and
# trusts the `x-user-id` header (provisioning a user on the fly).
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Payments (Polar.sh). Without POLAR_ACCESS_TOKEN the payment routes return 501.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# 'sandbox' while testing, 'production' when live (defaults to production).
POLAR_SERVER=production
# Product IDs from your Polar dashboard (one per plan).
POLAR_LIFETIME_PRODUCT_ID=
POLAR_MONTHLY_PRODUCT_ID=
POLAR_ANNUAL_PRODUCT_ID=

# Observability (Sentry). Without SENTRY_DSN error tracking is disabled (no-op).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# App
NODE_ENV=development
# FRONTEND_URL is the CORS allowlist (comma-separated for multiple origins) and
# the base URL for Stripe checkout redirects. In production, requests from
# origins not listed here are rejected.
PORT=3001
FRONTEND_URL=http://localhost:5173
