# Copy to .env to enable backend sync + auth/payments. All optional — the app
# runs fully on localStorage with none of these set.

# Point at the API to sync decisions/usage (server-side dashboard + leaks).
VITE_API_URL=http://localhost:3001

# Auth (Clerk). Setting this turns on the sign-in UI + bearer-token auth.
VITE_CLERK_PUBLISHABLE_KEY=
# Payments use Polar.sh hosted checkout (redirect) — no frontend key needed.
