# Copy to .env to enable backend sync + auth/payments. All optional — the app
# runs fully on localStorage with none of these set.

# Point at the API to sync decisions/usage (server-side dashboard + leaks).
VITE_API_URL=http://localhost:3001

# Auth (Clerk) and payments (Stripe) — wire when ready.
VITE_CLERK_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
